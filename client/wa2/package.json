{
   "name": "wa2",
   "displayName": "WA2 - Well-Architected 2",
   "description": "CloudFormation validation + Well-Architected 2 best practices. Real-time architectural guidance as you build.",
   "icon": "images/logo.png",
   "version": "0.1.11",
   "engines": {
      "vscode": "^1.95.0"
   },
   "publisher": "FigmentEngineLtd",
   "categories": [
      "Programming Languages",
      "Linters"
   ],
   "keywords": [
      "cloudformation",
      "aws",
      "well-architected",
      "infrastructure",
      "iaac",
      "cloud",
      "validation"
   ],
   "repository": {
      "type": "git",
      "url": "https://github.com/unremarkable-technology/wa2-vscode-extension"
   },
   "main": "./out/extension.js",
   "scripts": {
      "vscode:prepublish": "npm run bundle",
      "compile": "tsc -p ./",
      "bundle": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
      "watch": "tsc -watch -p ./",
      "pretest": "npm run compile && npm run lint",
      "lint": "eslint src",
      "test": "vscode-test"
   },
   "devDependencies": {
      "@types/mocha": "^10.0.10",
      "@types/node": "22.x",
      "@types/vscode": "^1.95.0",
      "@vscode/test-cli": "^0.0.12",
      "@vscode/test-electron": "^2.5.2",
      "esbuild": "^0.27.2",
      "eslint": "^9.39.1",
      "typescript": "^5.9.3",
      "typescript-eslint": "^8.46.3"
   },
   "dependencies": {
      "vscode-languageclient": "^9.0.1"
   },
   "overrides": {
      "minimatch@3.1.2": "3.1.4",
      "minimatch@5.1.7": "5.1.8",
      "minimatch@9.0.5": "9.0.7",
      "diff": "8.0.3",
      "serialize-javascript": "7.0.3"
   },
   "contributes": {
      "configuration": {
         "title": "WA2",
         "properties": {
            "wa2.serverPath": {
               "type": "string",
               "default": "",
               "description": "Absolute path to a local wa2lsp binary. When set, WA2 uses this instead of downloading a managed server."
            }
         }
      },
      "languages": [
         {
            "id": "cloudformation-yaml",
            "aliases": [
               "CloudFormation (YAML)",
               "cfn-yaml"
            ],
            "extensions": [
               ".yaml",
               ".yml"
            ],
            "configuration": "./language-configuration.json"
         },
         {
            "id": "cloudformation-json",
            "aliases": [
               "CloudFormation (JSON)",
               "cfn-json"
            ],
            "extensions": [
               ".json",
               ".cfn",
               ".template"
            ],
            "configuration": "./language-configuration.json"
         },
         {
            "id": "wa2",
            "aliases": [
               "WA2",
               "wa2"
            ],
            "extensions": [
               ".wa2"
            ],
            "configuration": "./language-configuration-wa2.json"
         }
      ],
      "grammars": [
         {
            "language": "wa2",
            "scopeName": "source.wa2",
            "path": "./syntaxes/wa2.tmLanguage.json"
         }
      ]
   }
}
