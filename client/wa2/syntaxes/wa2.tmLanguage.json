{
   "name": "WA2",
   "scopeName": "source.wa2",
   "patterns": [
      {
         "include": "#comments"
      },
      {
         "include": "#strings"
      },
      {
         "include": "#docAnnotations"
      },
      {
         "include": "#keywords"
      },
      {
         "include": "#controlFlow"
      },
      {
         "include": "#booleans"
      },
      {
         "include": "#numbers"
      },
      {
         "include": "#operators"
      },
      {
         "include": "#declarations"
      },
      {
         "include": "#qualifiedNames"
      },
      {
         "include": "#pathsAndSelectors"
      }
   ],
   "repository": {
      "comments": {
         "patterns": [
            {
               "name": "comment.line.double-slash.wa2",
               "match": "//.*$"
            }
         ]
      },
      "strings": {
         "patterns": [
            {
               "name": "string.quoted.double.wa2",
               "begin": "\"",
               "end": "\"",
               "patterns": [
                  {
                     "name": "constant.character.escape.wa2",
                     "match": "\\\\."
                  }
               ]
            },
            {
               "name": "string.quoted.single.wa2",
               "begin": "'",
               "end": "'",
               "patterns": [
                  {
                     "name": "constant.character.escape.wa2",
                     "match": "\\\\."
                  }
               ]
            }
         ]
      },
      "docAnnotations": {
         "patterns": [
            {
               "name": "meta.annotation.doc.wa2",
               "begin": "@#doc\\s*\\(",
               "beginCaptures": {
                  "0": {
                     "name": "entity.name.function.annotation.wa2"
                  }
               },
               "end": "\\)",
               "patterns": [
                  {
                     "include": "#comments"
                  },
                  {
                     "include": "#strings"
                  },
                  {
                     "name": "variable.parameter.annotation.wa2",
                     "match": "\\b(tldr|why)\\b(?=\\s*=)"
                  },
                  {
                     "name": "keyword.operator.assignment.wa2",
                     "match": "="
                  },
                  {
                     "name": "punctuation.separator.comma.wa2",
                     "match": ","
                  }
               ]
            }
         ]
      },
      "keywords": {
         "patterns": [
            {
               "name": "keyword.declaration.wa2",
               "match": "\\b(namespace|struct|enum|type|predicate|rule|derive|policy|instance|governance|profile|use)\\b"
            },
            {
               "name": "keyword.other.wa2",
               "match": "\\b(let|must|should|may|setting|as|strict|lazy)\\b"
            }
         ]
      },
      "controlFlow": {
         "patterns": [
            {
               "name": "keyword.control.wa2",
               "match": "\\b(for|in|if|else|match|return)\\b"
            }
         ]
      },
      "booleans": {
         "patterns": [
            {
               "name": "constant.language.boolean.wa2",
               "match": "\\b(true|false)\\b"
            }
         ]
      },
      "numbers": {
         "patterns": [
            {
               "name": "constant.numeric.wa2",
               "match": "\\b\\d+(?:\\.\\d+)?\\b"
            }
         ]
      },
      "operators": {
         "patterns": [
            {
               "name": "support.function.builtin.wa2",
               "match": "\\b(query|add)\\b(?=\\s*\\()"
            },
            {
               "name": "keyword.operator.arrow.wa2",
               "match": "=>"
            },
            {
               "name": "keyword.operator.logical.wa2",
               "match": "\\b(in)\\b(?=\\s*\\()"
            },
            {
               "name": "keyword.operator.assignment.wa2",
               "match": "="
            },
            {
               "name": "punctuation.separator.colon.wa2",
               "match": ":"
            },
            {
               "name": "punctuation.separator.slash.wa2",
               "match": "/"
            },
            {
               "name": "punctuation.separator.comma.wa2",
               "match": ","
            },
            {
               "name": "punctuation.terminator.wa2",
               "match": ";"
            },
            {
               "name": "punctuation.section.brackets.wa2",
               "match": "[\\[\\]\\(\\)\\{\\}]"
            }
         ]
      },
      "declarations": {
         "patterns": [
            {
               "name": "meta.declaration.namespace.wa2",
               "match": "\\b(namespace)\\s+([A-Za-z_][A-Za-z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.declaration.wa2"
                  },
                  "2": {
                     "name": "entity.name.namespace.wa2"
                  }
               }
            },
            {
               "name": "meta.declaration.type.wa2",
               "match": "\\b(struct|enum|type|predicate)\\s+([A-Za-z_][A-Za-z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.declaration.wa2"
                  },
                  "2": {
                     "name": "entity.name.type.wa2"
                  }
               }
            },
            {
               "name": "meta.declaration.rule.wa2",
               "match": "\\b(rule)\\s+([A-Za-z_][A-Za-z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.declaration.wa2"
                  },
                  "2": {
                     "name": "entity.name.function.wa2"
                  }
               }
            },
            {
               "name": "meta.declaration.policy.wa2",
               "match": "\\b(policy)\\s+([A-Za-z_][A-Za-z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.declaration.wa2"
                  },
                  "2": {
                     "name": "entity.name.type.policy.wa2"
                  }
               }
            },
            {
               "name": "meta.declaration.governance.wa2",
               "match": "\\b(governance)\\s+([A-Za-z_][A-Za-z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.declaration.wa2"
                  },
                  "2": {
                     "name": "entity.name.type.governance.wa2"
                  }
               }
            },
            {
               "name": "meta.declaration.instance.wa2",
               "match": "\\b(instance)\\s+([^\\s]+)\\s*:\\s*([^\\s]+)",
               "captures": {
                  "1": {
                     "name": "keyword.declaration.wa2"
                  },
                  "2": {
                     "name": "entity.name.variable.wa2"
                  },
                  "3": {
                     "name": "entity.name.type.wa2"
                  }
               }
            },
            {
               "name": "meta.declaration.derive.wa2",
               "match": "\\b(derive)\\s+([A-Za-z_][A-Za-z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.declaration.wa2"
                  },
                  "2": {
                     "name": "entity.name.function.wa2"
                  }
               }
            },
            {
               "name": "meta.declaration.profile.wa2",
               "match": "\\b(profile)\\s+([A-Za-z_][A-Za-z0-9_:]*)",
               "captures": {
                  "1": {
                     "name": "keyword.declaration.wa2"
                  },
                  "2": {
                     "name": "entity.name.type.profile.wa2"
                  }
               }
            }
         ]
      },
      "qualifiedNames": {
         "patterns": [
            {
               "name": "variable.other.qualified.wa2",
               "match": "\\b[A-Za-z_][A-Za-z0-9_]*:[A-Za-z_][A-Za-z0-9_]*\\b"
            }
         ]
      },
      "pathsAndSelectors": {
         "patterns": [
            {
               "name": "meta.path.selector.wa2",
               "match": "\\b[A-Za-z_][A-Za-z0-9_]*(:[A-Za-z_][A-Za-z0-9_]*)?(?:/[A-Za-z_\\*][A-Za-z0-9_\\*]*(?::[A-Za-z_][A-Za-z0-9_]*)?)*(?:\\[[^\\]]*\\])*\\b"
            },
            {
               "name": "keyword.operator.wildcard.wa2",
               "match": "\\*"
            },
            {
               "name": "keyword.operator.optional.wa2",
               "match": "\\?"
            }
         ]
      }
   }
}