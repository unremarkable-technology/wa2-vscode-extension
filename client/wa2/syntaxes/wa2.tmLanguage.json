{
   "name": "WA2",
   "scopeName": "source.wa2",
   "patterns": [
      {
         "include": "#comments"
      },
      {
         "include": "#strings"
      },
      {
         "include": "#operators"
      },
      {
         "include": "#keywords"
      },
      {
         "include": "#booleans"
      },
      {
         "include": "#numbers"
      },
      {
         "include": "#declarations"
      },
      {
         "include": "#qualifiedNames"
      },
      {
         "include": "#identifiers"
      }
   ],
   "repository": {
      "comments": {
         "patterns": [
            {
               "name": "comment.line.double-slash.wa2",
               "match": "//.*$"
            }
         ]
      },
      "strings": {
         "patterns": [
            {
               "name": "string.quoted.double.wa2",
               "begin": "\"",
               "end": "\"",
               "patterns": [
                  {
                     "name": "constant.character.escape.wa2",
                     "match": "\\\\."
                  }
               ]
            },
            {
               "name": "string.quoted.single.wa2",
               "begin": "'",
               "end": "'",
               "patterns": [
                  {
                     "name": "constant.character.escape.wa2",
                     "match": "\\\\."
                  }
               ]
            }
         ]
      },
      "operators": {
         "patterns": [
            {
               "name": "keyword.operator.query.wa2",
               "match": "\\?\\("
            },
            {
               "name": "keyword.operator.emit.wa2",
               "match": "\\+\\("
            },
            {
               "name": "keyword.operator.foreach.wa2",
               "match": "\\*\\("
            },
            {
               "name": "keyword.operator.coerce.wa2",
               "match": "~\\("
            },
            {
               "name": "keyword.operator.arrow.wa2",
               "match": "=>"
            },
            {
               "name": "keyword.operator.assign.wa2",
               "match": "="
            },
            {
               "name": "punctuation.separator.colon.wa2",
               "match": ":"
            },
            {
               "name": "punctuation.separator.slash.wa2",
               "match": "/"
            },
            {
               "name": "punctuation.separator.comma.wa2",
               "match": ","
            },
            {
               "name": "punctuation.terminator.semicolon.wa2",
               "match": ";"
            }
         ]
      },
      "keywords": {
         "patterns": [
            {
               "name": "keyword.control.wa2",
               "match": "\\b(namespace|struct|enum|type|predicate|rule|policy|instance|governance|let|must|should|setting|in)\\b"
            },
            {
               "name": "keyword.other.modifier.wa2",
               "match": "\\b(strict|lazy)\\b"
            }
         ]
      },
      "booleans": {
         "patterns": [
            {
               "name": "constant.language.boolean.wa2",
               "match": "\\b(true|false)\\b"
            }
         ]
      },
      "numbers": {
         "patterns": [
            {
               "name": "constant.numeric.wa2",
               "match": "\\b\\d+(?:\\.\\d+)?\\b"
            }
         ]
      },
      "declarations": {
         "patterns": [
            {
               "name": "meta.declaration.namespace.wa2",
               "match": "\\b(namespace)\\s+([A-Za-z_][A-Za-z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.control.wa2"
                  },
                  "2": {
                     "name": "entity.name.namespace.wa2"
                  }
               }
            },
            {
               "name": "meta.declaration.type.wa2",
               "match": "\\b(struct|enum|type|predicate|rule|policy|governance)\\s+([A-Za-z_][A-Za-z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.control.wa2"
                  },
                  "2": {
                     "name": "entity.name.type.wa2"
                  }
               }
            },
            {
               "name": "meta.declaration.instance.wa2",
               "match": "\\b(instance)\\s+([^\\s]+)\\s*:\\s*([^\\s]+)",
               "captures": {
                  "1": {
                     "name": "keyword.control.wa2"
                  },
                  "2": {
                     "name": "entity.name.variable.wa2"
                  },
                  "3": {
                     "name": "entity.name.type.wa2"
                  }
               }
            }
         ]
      },
      "qualifiedNames": {
         "patterns": [
            {
               "name": "variable.other.qualified.wa2",
               "match": "\\b[A-Za-z_][A-Za-z0-9_]*:[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
               "name": "variable.other.path.wa2",
               "match": "(?<!:)//[A-Za-z_][A-Za-z0-9_]*(?::[A-Za-z_][A-Za-z0-9_]*)?(?:/[A-Za-z_][A-Za-z0-9_]*(?::[A-Za-z_][A-Za-z0-9_]*)?)*(?:/\\*)?"
            }
         ]
      },
      "identifiers": {
         "patterns": [
            {
               "name": "identifier.wa2",
               "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            }
         ]
      }
   }
}